---
type Variant = 'accent' | 'primary' | 'secondary' | 'ghost';

interface Props {
  href?: string;
  variant?: Variant;
  disabled?: boolean;
  external?: boolean;
  download?: boolean | string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  disabled = false,
  external = false,
  download = undefined,
  class: className = '',
} = Astro.props;

const base =
  'inline-flex min-h-[var(--button-height)] items-center justify-center gap-2 rounded-[var(--radius-control)] px-5 py-2.5 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-app';
const variants = {
  accent: 'bg-accent !text-[var(--color-on-accent)] hover:brightness-95',
  primary: 'bg-primary text-white hover:brightness-110',
  secondary: 'border border-subtle bg-surface-raised text-white hover:border-border-strong',
  ghost: 'text-muted hover:text-white',
};
const disabledClass = 'cursor-not-allowed border border-border-strong bg-surface-raised text-muted';
---

{
  href && !disabled ? (
    <a
      href={href}
      download={download}
      target={external ? '_blank' : undefined}
      rel={external ? 'noreferrer' : undefined}
      class={`${base} ${variants[variant]} ${className}`}
    >
      <slot />
    </a>
  ) : (
    <span class={`${base} ${disabledClass} ${className}`} aria-disabled="true">
      <slot />
    </span>
  )
}
