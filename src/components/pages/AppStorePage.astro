---
import Button from '../Button.astro';
import CopyButton from '../CopyButton';
import PageHeader from '../PageHeader.astro';
import Section from '../Section.astro';
import Shell from '../Shell.astro';
import {
  DEFAULT_LOCALE,
  LANGUAGE_LABELS,
  SITE_LOCALES,
  absoluteLocalizedUrl,
  localizedUrl,
  type Locale,
} from '../../lib/i18n';
import { appStoreConfig, siteConfig } from '../../lib/siteConfig';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const metadataUrls = [
  {
    label: 'App Store Product URL',
    status: 'Live app',
    value: appStoreConfig.appStoreProductUrl,
    note: `Apple App ID: ${appStoreConfig.appleAppId}. Use this URL for iOS download CTAs and public app-store links.`,
  },
  {
    label: 'Google Play Listing URL',
    status: 'Live app',
    value: appStoreConfig.googlePlayListingUrl,
    note: 'Use this URL for Android download CTAs and public Google Play links.',
  },
  {
    label: 'Support URL',
    status: 'Required',
    value: appStoreConfig.supportUrl,
    note: 'Use this in App Store Connect for user support, bug reports, feedback, and feature requests.',
  },
  {
    label: 'Marketing URL',
    status: 'Optional',
    value: appStoreConfig.marketingUrl,
    note: 'Use this as the public product page where users can learn what Universal Fit does.',
  },
  {
    label: 'Privacy Policy URL',
    status: 'Required',
    value: appStoreConfig.privacyPolicyUrl,
    note: 'Use this for the App Privacy privacy policy field.',
  },
  {
    label: 'User Privacy Choices URL',
    status: 'Optional',
    value: appStoreConfig.userPrivacyChoicesUrl,
    note: 'Use this if App Store Connect asks for a user privacy choices URL.',
  },
];

const localizedRows = SITE_LOCALES.map((item) => ({
  locale: item,
  label: LANGUAGE_LABELS[item],
  support: absoluteLocalizedUrl('/support', item),
  marketing: absoluteLocalizedUrl('/', item),
  privacy: absoluteLocalizedUrl('/privacy', item),
}));
---

<Shell
  locale={locale}
  canonicalPath="/app-store"
  title="Store URLs"
  description="Copy-ready Universal Fit URLs for App Store Connect and Google Play Console metadata."
>
  <PageHeader
    eyebrow="Store compliance"
    title="Store listing URLs"
    intro="Copy-ready URLs for the App Store Connect and Google Play Console fields needed before review."
  />

  <Section class="pt-0">
    <div class="grid gap-4 lg:grid-cols-2">
      {metadataUrls.map((item) => (
        <article class="surface-card p-5">
          <div class="flex flex-wrap items-center gap-2">
            <p class="rounded-[6px] bg-accent-soft px-2.5 py-1 text-xs font-black uppercase text-accent">{item.status}</p>
            <h2 class="text-2xl font-black text-white">{item.label}</h2>
          </div>
          <a href={item.value} class="mt-4 block break-all font-mono text-sm leading-6 text-accent">
            {item.value}
          </a>
          <p class="mt-3 leading-7 text-muted">{item.note}</p>
          <div class="mt-5 flex flex-wrap gap-3">
            <CopyButton client:load text={item.value} label="Copy URL" className="!text-[var(--color-on-accent)]" />
            <Button href={item.value} external variant="secondary">Open</Button>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section
    eyebrow="Review readiness"
    title="What these URLs cover."
    intro="These are the public web surfaces store review teams can visit without a login."
  >
    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-[var(--radius-card)] border border-subtle bg-surface p-5">
        <h2 class="text-xl font-black text-white">Support contact</h2>
        <p class="mt-3 leading-7 text-muted">
          The support page includes GitHub issue forms and a direct support email:
          <a class="ml-1 font-semibold text-accent" href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>.
        </p>
      </div>
      <div class="rounded-[var(--radius-card)] border border-subtle bg-surface p-5">
        <h2 class="text-xl font-black text-white">Marketing information</h2>
        <p class="mt-3 leading-7 text-muted">
          The marketing URL points to the product homepage with app positioning, screenshots, example plans, docs, and download CTAs.
        </p>
      </div>
      <div class="rounded-[var(--radius-card)] border border-subtle bg-surface p-5">
        <h2 class="text-xl font-black text-white">Privacy policy</h2>
        <p class="mt-3 leading-7 text-muted">
          The privacy policy describes the current offline-first app, website behavior, local device storage, deletion posture, and store disclosure update process.
        </p>
      </div>
      <div class="rounded-[var(--radius-card)] border border-subtle bg-surface p-5">
        <h2 class="text-xl font-black text-white">App review notes</h2>
        <p class="mt-3 leading-7 text-muted">
          Universal Fit does not require an account for the current core workflow. If login, subscriptions, analytics, cloud sync, or tracking are added later, update this page and App Store Connect before review.
        </p>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Localized metadata"
    title="Localized URL options."
    intro="App Store Connect and Google Play Console can localize support and marketing URLs. Use the default English URLs unless you want a locale-specific listing."
  >
    <div class="overflow-x-auto rounded-[var(--radius-card)] border border-subtle">
      <table class="w-full min-w-[48rem] border-collapse bg-surface text-left text-sm">
        <thead class="text-white">
          <tr>
            <th class="border-b border-subtle p-4">Locale</th>
            <th class="border-b border-subtle p-4">Support</th>
            <th class="border-b border-subtle p-4">Marketing</th>
            <th class="border-b border-subtle p-4">Privacy</th>
          </tr>
        </thead>
        <tbody class="text-muted">
          {localizedRows.map((row) => (
            <tr>
              <td class="border-b border-subtle p-4 font-semibold text-white">{row.label}</td>
              <td class="border-b border-subtle p-4"><a class="break-all text-accent" href={row.support}>{row.support}</a></td>
              <td class="border-b border-subtle p-4"><a class="break-all text-accent" href={row.marketing}>{row.marketing}</a></td>
              <td class="border-b border-subtle p-4"><a class="break-all text-accent" href={row.privacy}>{row.privacy}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      <Button href={localizedUrl('/support', locale)} variant="primary">Open support page</Button>
      <Button href={localizedUrl('/privacy', locale)} variant="secondary">Open privacy policy</Button>
    </div>
  </Section>
</Shell>
