---
import Badge from '../Badge.astro';
import Button from '../Button.astro';
import Card from '../Card.astro';
import DownloadButtons from '../DownloadButtons.astro';
import PhonePreview from '../PhonePreview.astro';
import Section from '../Section.astro';
import Shell from '../Shell.astro';
import { DEFAULT_LOCALE, getMessages, localizedUrl, type Locale } from '../../lib/i18n';
import { loadPlans } from '../../lib/plans';
import { withBase } from '../../lib/siteConfig';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const messages = getMessages(locale);
const plans = await loadPlans(locale);
const heroImage = withBase('/assets/screens/app-overview.webp');
const modalityLabels = messages.taxonomy.modality as Record<string, string>;
const screenImages = [
  '/assets/screens/screen-library.webp',
  '/assets/screens/screen-import-plan.webp',
  '/assets/screens/screen-generate-ai.webp',
  '/assets/screens/screen-history.webp',
  '/assets/screens/screen-settings.webp',
];
const screenCards = messages.home.screens.cards.map((card, index) => {
  const title = card[0] ?? '';
  const copy = card[1] ?? '';
  const alt = card[2] ?? title;
  const image = screenImages[index] ?? '/assets/screens/screen-library.webp';
  return {
    title,
    copy,
    alt,
    image: withBase(image),
  };
});
---

<Shell locale={locale} canonicalPath="/">
  <section
    class="relative min-h-[78vh] overflow-hidden border-b border-subtle"
    style={`background-image: linear-gradient(90deg, rgba(13,13,13,0.98) 0%, rgba(13,13,13,0.84) 48%, rgba(13,13,13,0.54) 100%), url('${heroImage}'); background-size: cover; background-position: center right;`}
  >
    <div class="mx-auto flex min-h-[78vh] w-full max-w-[var(--page-max)] items-center px-[var(--page-pad)] py-16">
      <div class="max-w-3xl">
        <Badge tone="accent">{messages.home.badge}</Badge>
        <h1 class="mt-6 text-5xl font-black leading-[1.02] text-white md:text-6xl">{messages.home.title}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">{messages.home.intro}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={localizedUrl('/plans', locale)} variant="accent">{messages.home.browsePlans}</Button>
          <Button href={localizedUrl('/generate-with-ai', locale)} variant="secondary">{messages.home.buildWorkout}</Button>
        </div>
        <DownloadButtons locale={locale} class="mt-4" />
      </div>
    </div>
  </section>

  <Section eyebrow={messages.home.why.eyebrow} title={messages.home.why.title} intro={messages.home.why.intro}>
    <div class="grid gap-4 md:grid-cols-3">
      {messages.home.why.cards.map(([title, copy]) => (
        <Card>
          <h2 class="text-xl font-black text-white">{title}</h2>
          <p class="mt-3 leading-7 text-muted">{copy}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section eyebrow={messages.home.builder.eyebrow} title={messages.home.builder.title} intro={messages.home.builder.intro}>
    <div class="grid gap-4 md:grid-cols-3">
      {messages.home.builder.cards.map(([title, copy]) => (
        <Card>
          <h2 class="text-xl font-black text-white">{title}</h2>
          <p class="mt-3 leading-7 text-muted">{copy}</p>
        </Card>
      ))}
    </div>
    <div class="mt-5">
      <Button href={localizedUrl('/generate-with-ai#builder', locale)} variant="primary">{messages.home.builder.cta}</Button>
    </div>
  </Section>

  <Section eyebrow={messages.home.app.eyebrow} title={messages.home.app.title} intro={messages.home.app.intro}>
    <div class="grid items-center gap-10 lg:grid-cols-[1fr_22rem]">
      <div class="grid gap-4 sm:grid-cols-2">
        {messages.home.app.cards.map(([title, copy]) => (
          <div class="rounded-[var(--radius-card)] border border-subtle bg-surface p-5">
            <h3 class="font-black text-white">{title}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">{copy}</p>
          </div>
        ))}
      </div>
      <PhonePreview image={withBase('/assets/screens/workout-home.webp')} alt={messages.home.app.phoneAlt} />
    </div>
  </Section>

  <Section eyebrow={messages.home.screens.eyebrow} title={messages.home.screens.title} intro={messages.home.screens.intro}>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {screenCards.map((screen) => (
        <figure class="surface-card overflow-hidden p-0">
          <img
            src={screen.image}
            alt={screen.alt}
            class="aspect-[24/41] w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="border-t border-subtle p-4">
            <h3 class="text-sm font-black text-white">{screen.title}</h3>
            <p class="mt-2 text-xs leading-5 text-muted">{screen.copy}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <Section eyebrow={messages.home.examples.eyebrow} title={messages.home.examples.title} intro={messages.home.examples.intro}>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {plans.map((plan) => (
        <a href={plan.detailUrl} class="surface-card block p-5 transition hover:border-accent">
          <Badge tone={plan.modality === 'running' ? 'primary' : plan.modality === 'mobility' ? 'success' : 'accent'}>
            {modalityLabels[plan.modality] || plan.modality}
          </Badge>
          <h3 class="mt-4 text-lg font-black leading-tight text-white">{plan.name}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{plan.durationWeeks} {messages.common.weeks} · {plan.daysPerWeek} {messages.common.daysPerWeek}</p>
        </a>
      ))}
    </div>
  </Section>

  <Section eyebrow={messages.home.project.eyebrow} title={messages.home.project.title} intro={messages.home.project.intro}>
    <div class="flex flex-wrap gap-3">
      <Button href={localizedUrl('/support', locale)} variant="primary">{messages.home.project.support}</Button>
      <Button href={localizedUrl('/roadmap', locale)} variant="secondary">{messages.home.project.roadmap}</Button>
    </div>
  </Section>
</Shell>
