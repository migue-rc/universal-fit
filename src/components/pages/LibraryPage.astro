---
import Badge from '../Badge.astro';
import PageHeader from '../PageHeader.astro';
import Section from '../Section.astro';
import Shell from '../Shell.astro';
import { DEFAULT_LOCALE, getMessages, interpolate, type Locale } from '../../lib/i18n';
import { loadExercises } from '../../lib/exercises';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const messages = getMessages(locale);
const exercises = await loadExercises(locale);
const total = exercises.length;
const shown = exercises.slice(0, 120);
---

<Shell locale={locale} canonicalPath="/docs/library" title={messages.docs.library.title} description={messages.docs.library.description}>
  <PageHeader
    eyebrow={messages.docs.docs}
    title={messages.docs.library.heading}
    intro={interpolate(messages.docs.library.intro, { shown: shown.length, total })}
  />
  <Section class="pt-0">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {shown.map((exercise) => (
        <article class="surface-card p-5">
          <div class="flex flex-wrap gap-2">
            <Badge tone={exercise.type === messages.taxonomy.modality.mobility ? 'success' : 'primary'}>{exercise.type}</Badge>
            <Badge tone="neutral">{exercise.experience}</Badge>
          </div>
          <h2 class="mt-4 text-xl font-black leading-tight text-white">{exercise.name}</h2>
          <p class="mt-2 font-mono text-xs text-faint">{exercise.id}</p>
          <div class="mt-4 grid gap-2 text-sm text-muted">
            <p><span class="text-white">{messages.taxonomy.exercise.pattern}:</span> {exercise.movementPattern}</p>
            <p><span class="text-white">{messages.taxonomy.exercise.primary}:</span> {exercise.primaryMuscle}</p>
            <p><span class="text-white">{messages.taxonomy.exercise.equipment}:</span> {exercise.equipment.join(', ') || messages.common.none}</p>
          </div>
          {exercise.cues.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {exercise.cues.map((cue) => (
                <span class="rounded-[6px] border border-subtle px-2 py-1 text-xs text-muted">{cue}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </Section>
</Shell>
