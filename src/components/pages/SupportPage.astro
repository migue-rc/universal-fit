---
import Button from '../Button.astro';
import Card from '../Card.astro';
import CopyButton from '../CopyButton';
import PageHeader from '../PageHeader.astro';
import Section from '../Section.astro';
import Shell from '../Shell.astro';
import { DEFAULT_LOCALE, getMessages, localizedUrl, type Locale } from '../../lib/i18n';
import { appStoreConfig, issueTemplateUrl, siteConfig } from '../../lib/siteConfig';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const messages = getMessages(locale);
const templates = ['bug_report.yml', 'feature_request.yml', 'plan_submission.yml', 'schema_feedback.yml'];
---

<Shell locale={locale} canonicalPath="/support" title={messages.support.title} description={messages.support.description}>
  <PageHeader eyebrow={messages.support.eyebrow} title={messages.support.heading} intro={messages.support.intro} />
  <Section class="pt-0">
    <div class="surface-card grid gap-5 p-5 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="text-sm font-black uppercase text-accent">App Store support URL</p>
        <h2 class="mt-3 text-2xl font-black text-white">Support for users and App Review.</h2>
        <p class="mt-3 max-w-3xl leading-7 text-muted">
          Use this page as the App Store Connect Support URL. It includes public issue forms and direct contact at
          <a class="ml-1 font-semibold text-accent" href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>.
        </p>
        <a href={appStoreConfig.supportUrl} class="mt-3 block break-all font-mono text-sm text-accent">{appStoreConfig.supportUrl}</a>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <CopyButton client:load text={appStoreConfig.supportUrl} label="Copy support URL" className="!text-[var(--color-on-accent)]" />
        <Button href={localizedUrl('/app-store', locale)} variant="secondary">All App Store URLs</Button>
      </div>
    </div>
  </Section>
  <Section class="pt-0">
    <div class="grid gap-4 md:grid-cols-2">
      {messages.support.cards.map(([title, copy, cta], index) => (
        <Card>
          <h2 class="text-2xl font-black text-white">{title}</h2>
          <p class="mt-3 leading-7 text-muted">{copy}</p>
          <Button href={issueTemplateUrl(templates[index])} external variant="accent" class="mt-6">{cta}</Button>
        </Card>
      ))}
    </div>
  </Section>
  <Section eyebrow={messages.support.before.eyebrow} title={messages.support.before.title} intro={messages.support.before.intro}>
    <div class="flex flex-wrap gap-3">
      <Button href={siteConfig.repoUrl + '/issues'} external variant="secondary">{messages.support.before.issues}</Button>
      <Button href={localizedUrl('/docs/llm-brief', locale)} variant="ghost">{messages.support.before.brief}</Button>
    </div>
  </Section>
</Shell>
